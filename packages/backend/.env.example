# BarclaudeGateway backend — local secrets (NEVER commit a real .env; .env* is git-ignored).
# Copy to .env and fill in. Used by the optional manual smoke-test (`npm run auth:smoke`).

# Chronodrive account used for the live smoke-test only.
BCG_CHRONODRIVE_EMAIL=you@example.com
BCG_CHRONODRIVE_PASSWORD=your-password

# 32-byte AES-256 master key (hex or base64) that encrypts stored credentials at rest.
# Not needed by the smoke-test; required by the app at runtime. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BCG_MASTER_KEY=

# Optional: override the SQLite file path (defaults to ./data/barclaudegateway.sqlite).
# BCG_DB_PATH=./data/barclaudegateway.sqlite

# Optional: HTTP server bind for the ingestion endpoint (defaults: 8090 on all interfaces).
# 8090 rather than the usual 8080, which is commonly already taken on the host.
# BCG_PORT=8090
# BCG_HOST=0.0.0.0

# --- ingest:smoke only (optional manual end-to-end scan test) ---------------------------------
# Read-only by default: it resolves a known EAN to confirm auth + search + the §3 Origin/Referer
# requirement, and writes NOTHING. To also exercise the real write path (mutates your account),
# set BCG_SMOKE_WRITE=true and pick at least one destination below.
# BCG_SMOKE_WRITE=false
# BCG_SMOKE_CART=false
# BCG_SMOKE_LIST_ID=
# BCG_SMOKE_EAN=3183280000933
