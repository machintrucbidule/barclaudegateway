# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Test coverage
coverage/

# Environment & secrets — NEVER commit these (Chronodrive credentials live here at runtime)
.env
.env.*
!.env.example

# Local database (SQLite) — runtime data, see DECISION-003
*.sqlite
*.sqlite3
*.db

# Local Windows test environment (scripts/windows/*.bat) — holds the test SQLite
# DB and the generated test master key. NEVER commit (the key is a secret).
.testdata/

# Local secrets for deploy_prod.bat (the Watchtower API token). The versioned
# deploy_prod.bat sources this companion file at run time. NEVER commit it.
scripts/windows/deploy_prod.secret.bat

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS noise
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Vite cache
.vite/
